  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "start": "serve -s dist -l ${PORT:-8080}",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:run": "vitest run",
    "test:serverless-api": "vitest run tests/api/serverlessApiImportSmoke.test.ts",
    "test:critical:production": "vitest run tests/api/serverlessApiImportSmoke.test.ts tests/services/emailOutboxProcessor.test.ts tests/services/emailCrossModuleDispatcher.test.ts tests/services/emailProviderReadiness.test.ts tests/services/appointmentEmailDeliveryService.test.ts tests/services/appointmentGoogleCalendarSyncService.test.ts tests/utils/ecommerceEmailService.test.ts tests/utils/storefrontRouter.test.ts tests/utils/storefrontRenderer.test.ts tests/services/bioPageEngineService.test.ts",
    "test:coverage": "vitest run --coverage",
    "test:integration": "vitest run tests/integration",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "type-check": "tsc --noEmit",
    "type-check:serverless-api": "tsc --noEmit --pretty false --skipLibCheck --allowImportingTsExtensions true services/email/serverless/emailProviderService.ts services/email/serverless/emailOutboxProcessor.ts services/email/serverless/emailCrossModuleDispatcher.ts services/appointments/serverless/appointmentEmailDeliveryService.ts api/email/jobs/run.ts api/appointments/jobs/run.ts api/appointments/google/jobs/run.ts api/mcp/jobs/run.ts",
    "ds:audit": "tsx scripts/audit-design-system.ts",
    "lint": "echo 'Linting...' && exit 0",
    "deploy": "vercel deploy --prod",
    "deploy:preview": "vercel deploy",
    "deploy:quick": "vercel deploy --prod --yes",
    "deploy:ai-proxy": "supabase functions deploy ai-proxy --project-ref elfcrnhffuvntlfuvumd"
  },
