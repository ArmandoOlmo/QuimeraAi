{
  "$schema": "https://unpkg.com/wrangler@4/config-schema.json",
  "name": "quimeraai",
  "compatibility_date": "2026-06-25",
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "observability": {
    "enabled": true
  },
  "assets": {
    "directory": "./dist",
    "not_found_handling": "single-page-application"
  }
}
