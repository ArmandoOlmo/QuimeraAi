# ============================================
# QUIMERA AI - Environment Variables
# ============================================
# Copy this file to .env and fill in your values
# NEVER commit .env to version control!

# Supabase Configuration
VITE_SUPABASE_URL=your_supabase_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key
VITE_AI_PROXY_URL=your_supabase_url/functions/v1/ai-proxy
VITE_VIDEO_PROXY_URL=your_supabase_url/functions/v1/ai-proxy
VITE_WIDGET_API_BASE_URL=https://quimera.ai/api/widget
VITE_STRIPE_PUBLISHABLE_KEY=your_stripe_publishable_key

# Server-side AI provider secrets (set in Supabase/Vercel, never as VITE_)
OPENROUTER_API_KEY=your_openrouter_api_key

# Vercel serverless cron/API secrets (server-only; never prefix with VITE_)
CRON_SECRET=your_long_random_cron_secret
SUPABASE_URL=your_supabase_url
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Email provider secrets (server-only)
RESEND_API_KEY=your_resend_api_key
SENDGRID_API_KEY=your_sendgrid_api_key_if_used
RESEND_FROM_EMAIL=Quimera Ai <no-reply@your-domain.com>
APPOINTMENT_EMAIL_FROM=Quimera Ai <appointments@your-domain.com>
EMAIL_OUTBOX_JOB_LIMIT=50
EMAIL_OUTBOX_MAX_PER_RUN=50
EMAIL_OUTBOX_MAX_PER_MINUTE=60
EMAIL_OUTBOX_RETRY_AFTER_SECONDS=60
APPOINTMENT_EMAIL_JOB_LIMIT=25

# Stripe server-side secrets
STRIPE_SECRET_KEY=your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=your_stripe_webhook_secret
STRIPE_SYNC_SECRET=your_long_random_stripe_sync_secret

# Google Calendar server-side OAuth/sync secrets
GOOGLE_CALENDAR_CLIENT_SECRET=your_google_calendar_client_secret
GOOGLE_CALENDAR_TOKEN_ENCRYPTION_KEY=32_byte_hex_or_base64_key
GOOGLE_CALENDAR_OAUTH_STATE_SECRET=your_google_calendar_oauth_state_secret
GOOGLE_CALENDAR_REDIRECT_URI=https://www.quimera.ai/api/appointments/google/oauth/callback
GOOGLE_CALENDAR_WEBHOOK_URL=https://www.quimera.ai/api/appointments/google/webhook
GOOGLE_CALENDAR_SYNC_JOB_LIMIT=25

# Public/server URL contract
APP_BASE_URL=https://www.quimera.ai
VITE_PUBLIC_APP_URL=https://www.quimera.ai

# Cloudflare provider secrets are server-only. Do not use VITE-prefixed Cloudflare tokens.
CLOUDFLARE_API_TOKEN=your_cloudflare_api_token
CLOUDFLARE_ACCOUNT_ID=your_cloudflare_account_id

# Google Maps API (for geocoding and map display)
# Get your key at: https://console.cloud.google.com/google/maps-apis
# Enable: Maps JavaScript API, Geocoding API
VITE_GOOGLE_MAPS_KEY=your_google_maps_api_key

# Google Calendar API (optional)
VITE_GOOGLE_API_KEY=your_google_api_key
VITE_GOOGLE_CLIENT_ID=your_google_client_id

# Meta OAuth for ChatCore social channels (requires backend support)
VITE_META_OAUTH_ENABLED=false

# Owner Email - Usuario con acceso completo sin restricciones de plan
VITE_OWNER_EMAIL=your_email@example.com

# MCP API base URL.
# Optional in production. Useful for local Vite dev because Vercel API routes
# are not executed by the Vite dev server.
VITE_MCP_API_BASE_URL=https://www.quimera.ai
