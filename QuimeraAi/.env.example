# ============================================
# QUIMERA AI - Environment Variables
# ============================================
# Copy this file to .env and fill in your values
# NEVER commit .env to version control!

# Supabase Configuration
VITE_SUPABASE_URL=your_supabase_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key
VITE_AI_PROXY_URL=your_supabase_url/functions/v1/ai-proxy
VITE_VIDEO_PROXY_URL=your_supabase_url/functions/v1/ai-proxy
VITE_WIDGET_API_BASE_URL=https://quimera.ai/api/widget

# Server-side AI provider secrets (set in Supabase/Vercel, never as VITE_)
OPENROUTER_API_KEY=your_openrouter_api_key

# Google Maps API (for geocoding and map display)
# Get your key at: https://console.cloud.google.com/google/maps-apis
# Enable: Maps JavaScript API, Geocoding API
VITE_GOOGLE_MAPS_KEY=your_google_maps_api_key

# Google Calendar API (optional)
VITE_GOOGLE_API_KEY=your_google_api_key
VITE_GOOGLE_CLIENT_ID=your_google_client_id

# Meta OAuth for ChatCore social channels (requires backend support)
VITE_META_OAUTH_ENABLED=false

# Deployment Providers (Cloudflare)
VITE_CLOUDFLARE_TOKEN=your_cloudflare_token
VITE_CLOUDFLARE_ACCOUNT_ID=your_cloudflare_account_id

# Owner Email - Usuario con acceso completo sin restricciones de plan
VITE_OWNER_EMAIL=your_email@example.com

# MCP API base URL.
# Optional in production. Useful for local Vite dev because Vercel API routes
# are not executed by the Vite dev server.
VITE_MCP_API_BASE_URL=https://www.quimera.ai
