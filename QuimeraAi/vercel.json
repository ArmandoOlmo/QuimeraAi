{
  "buildCommand": "vite build",
  "outputDirectory": "dist",
  "framework": "vite",
  "crons": [
    {
      "path": "/api/mcp/jobs/run",
      "schedule": "0 12 * * *"
    },
    {
      "path": "/api/appointments/jobs/run",
      "schedule": "*/15 * * * *"
    },
    {
      "path": "/api/appointments/google/jobs/run",
      "schedule": "*/15 * * * *"
    }
  ],
  "rewrites": [
    { "source": "/((?!api/).*)", "destination": "/" }
  ]
}
